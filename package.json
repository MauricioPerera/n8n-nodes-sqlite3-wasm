{
    "name": "n8n-nodes-sqlite3-wasm",
    "version": "1.0.1",
    "description": "n8n community node to run SQL against a local SQLite database via node-sqlite3-wasm",
    "license": "MIT",
    "homepage": "https://github.com/MauricioPerera/n8n-nodes-sqlite3-wasm#readme",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "Mauricio Perera",
        "email": "mauricio.perera@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MauricioPerera/n8n-nodes-sqlite3-wasm.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/SqliteApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Sqlite/Sqlite.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "@types/jest": "^30.0.0",
        "@types/node": "^26.0.1",
        "eslint": "9.32.0",
        "jest": "^30.4.2",
        "n8n-workflow": "*",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "ts-jest": "^29.4.11",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "dependencies": {
        "node-sqlite3-wasm": "^0.8.59"
    }
}
